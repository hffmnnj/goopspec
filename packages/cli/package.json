{
  "name": "@goopspec/cli",
  "version": "0.1.0",
  "description": "GoopSpec CLI — configure, manage, and control GoopSpec",
  "type": "module",
  "bin": {
    "goopspec": "./dist/index.js",
    "goop": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --external cfonts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "fuzzysort": "^3.0.2",
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "react": "^18.2.0",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0",
    "@biomejs/biome": "^1.9.4"
  }
}
