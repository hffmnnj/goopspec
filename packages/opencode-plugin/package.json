{
  "name": "@goopspec/opencode-plugin",
  "version": "1.0.0",
  "description": "GoopSpec — spec-driven development plugin for OpenCode",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "agents",
    "commands",
    "references"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "lint": "echo 'lint not yet configured — see Task 2.3'"
  },
  "keywords": [
    "opencode",
    "plugin",
    "spec-driven",
    "agent-orchestration",
    "goopspec"
  ],
  "author": "James",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.1.44",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "bun-types": "latest",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.1.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hffmnnj/opencode-goopspec.git"
  }
}
