{
  "name": "goopspec",
  "version": "1.0.0",
  "private": true,
  "description": "A spec-driven development plugin for OpenCode with user-guided planning, wave execution, and verification",
  "type": "module",
  "scripts": {
    "build": "bun run --cwd packages/opencode-plugin build",
    "lint": "bun run --cwd packages/opencode-plugin lint",
    "format": "bun run --cwd packages/opencode-plugin format",
    "typecheck": "bun run --cwd packages/opencode-plugin typecheck",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('packages/opencode-plugin/dist',{recursive:true,force:true})\"",
    "test": "bun test --cwd packages/opencode-plugin",
    "packages": "bun pm pkg get workspaces",
    "version:bump": "bun scripts/version-bump.ts",
    "prepublishOnly": "bun run build"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "spec-driven",
    "task-management",
    "agent-orchestration",
    "productivity",
    "task-continuation",
    "enforced-continuation",
    "goopspec"
  ],
  "author": "James",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.13.9",
    "bun-types": "latest",
    "typescript": "^5.8.2"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hffmnnj/opencode-goopspec.git"
  },
  "bugs": {
    "url": "https://github.com/hffmnnj/opencode-goopspec/issues"
  },
  "homepage": "https://github.com/hffmnnj/opencode-goopspec#readme"
}
