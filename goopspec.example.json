{
  "_comment": "GoopSpec 1.0.0 configuration example. Place as goopspec.json in your project root.",
  "projectName": "my-awesome-app",
  "enforcement": "warn",
  "_enforcement_comment": "assist = gentle guidance, warn = highlight issues, strict = enforce gates and constraints.",
  "adlEnabled": true,
  "defaultModel": "anthropic/claude-sonnet-4-6",
  "agents": {
    "goop-explorer": {
      "model": "google/gemini-2.5-flash",
      "temperature": 0.3
    },
    "goop-researcher": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.3
    },
    "goop-tester": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2
    },
    "goop-writer": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.3
    },
    "goop-debugger": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2
    },
    "goop-executor-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2
    },
    "goop-executor-medium": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2
    },
    "goop-executor-high": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.2
    },
    "goop-executor-frontend-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.2
    },
    "goop-executor-frontend-high": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.3
    },
    "goop-orchestrator": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.1
    },
    "goop-planner": {
      "model": "anthropic/claude-opus-4-6",
      "temperature": 0.2
    },
    "goop-verifier": {
      "model": "anthropic/claude-sonnet-4-6",
      "temperature": 0.1
    }
  }
}
